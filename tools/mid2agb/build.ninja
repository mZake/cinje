cxx = g++

cxxflags = -std=c++11 -O2 -Wall -Wno-switch -Werror

build tools/mid2agb/mid2agb: host_cxx tools/mid2agb/agb.cpp tools/mid2agb/error.cpp tools/mid2agb/main.cpp tools/mid2agb/midi.cpp tools/mid2agb/tables.cpp | tools/mid2agb/agb.h tools/mid2agb/error.h tools/mid2agb/main.h tools/mid2agb/tables.h
